{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "praxis",
  "version": "1.1.0",
  "identifier": "com.axiomorient.praxis",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "praxis",
        "width": 1480,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
